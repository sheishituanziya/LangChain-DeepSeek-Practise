DEEPSEEK_API_KEY = your DEEPSEEK_API_KEY
DEEPSEEK_API_BASE = https://api.deepseek.com/v1

chat_memory_file_path = ./file/4_chat_history.json

mysql_conn_str = mysql+pymysql://root:root@localhost:3306/

sqlite_db_path = ./file/4_chat_history.db
sqlite_chat_memory_table_name = 4_chat_history

redis_url = redis://localhost:6379/5
redis_chat_memory_prefix = chat_history

mongo_connection_string = mongodb://localhost:27017
mongo_chat_memory_db = chat_db
mongo_chat_memory_collection = chat_history

postgres_connection_string = postgresql://postgres:root@localhost:5432/postgres
postgres_chat_memory_table_name = chat_history

weather_id = your api_key
weather_secret = your api_secret
